{
  "devices": {
    "Refrigerator": "192.168.1.198",
    "Frezer": "192.168.1.128",
    "Printer": "192.168.1.111"
  },
  "telegram-token": "your_bot_token_here",
  "telegram-chat-id": "your_chat_id_here",
  "interval": "60s",
  "failure-threshold": 3,
  "recovery-notify": true,
  "ping-timeout": "5s",
  "debug": false,
  "log-file": "~/iotping.log",
  "repeat-interval": "1h",
  "max-repeat-notifications": 3
}
